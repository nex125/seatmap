{
  "name": "@nex125/seatmap-viewer",
  "version": "0.1.18",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./src/theme/seatmapViewerTheme.css"
  },
  "sideEffects": [
    "./src/theme/seatmapViewerTheme.css"
  ],
  "files": [
    "dist",
    "src/theme/seatmapViewerTheme.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "verify:package-exports": "bun run scripts/verify-package-exports.ts",
    "prepack": "bun run clean && bun run build && bun run verify:package-exports",
    "prepublishOnly": "bun run prepack"
  },
  "dependencies": {
    "@nex125/seatmap-core": "*",
    "@nex125/seatmap-react": "*"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "pixi.js": "^8"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "pixi.js": "^8",
    "tsup": "^8.4.0",
    "typescript": "~5.9.3"
  }
}
