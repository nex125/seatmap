{
  "name": "@nex125/seatmap-core",
  "version": "0.1.17",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "verify:package-exports": "bun run scripts/verify-package-exports.ts",
    "prepack": "bun run clean && bun run build && bun run verify:package-exports",
    "prepublishOnly": "bun run prepack"
  },
  "peerDependencies": {
    "pixi.js": "^8"
  },
  "devDependencies": {
    "@types/rbush": "^4.0.0",
    "pixi.js": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "rbush": "^4.0.1",
    "uuid": "^14.0.0"
  }
}
