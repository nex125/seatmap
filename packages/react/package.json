{
  "name": "@nex125/seatmap-react",
  "version": "0.1.20",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "verify:package-exports": "bun run scripts/verify-package-exports.ts",
    "prepack": "bun run clean && bun run build && bun run verify:package-exports",
    "prepublishOnly": "bun run prepack"
  },
  "dependencies": {
    "@nex125/seatmap-core": "^0.1.17",
    "pixi.js": "^8.18.1",
    "@pixi/react": "^8.0.5",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3"
  }
}
